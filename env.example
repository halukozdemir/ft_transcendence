# ============================================
# ft_transcendence - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp env.example .env

# ---------- General ----------
DOMAIN=localhost
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=0

# ---------- PostgreSQL (Auth / User DB) ----------
POSTGRES_USER_DB=ft_user_db
POSTGRES_USER_USER=ft_user
POSTGRES_USER_PASSWORD=change_me_user_password
POSTGRES_USER_HOST=db_user
POSTGRES_USER_PORT=5432

# ---------- PostgreSQL (Game / Stats DB) ----------
POSTGRES_STATS_DB=ft_stats_db
POSTGRES_STATS_USER=ft_stats
POSTGRES_STATS_PASSWORD=change_me_stats_password
POSTGRES_STATS_HOST=db_stats
POSTGRES_STATS_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis_broker
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------- OAuth (42 API) ----------
OAUTH_42_CLIENT_ID=your_42_client_id
OAUTH_42_CLIENT_SECRET=your_42_client_secret
OAUTH_42_REDIRECT_URI=https://localhost/api/auth/oauth/callback

# ---------- AI Service ----------
AI_SERVICE_HOST=ai_service
AI_SERVICE_PORT=8002

# ---------- Frontend ----------
REACT_APP_API_URL=https://localhost/api
