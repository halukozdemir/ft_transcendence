# ============================================
# ft_transcendence - Environment Variables
# ============================================

# ---------- General ----------
DOMAIN=localhost
DJANGO_SECRET_KEY=dev-secret-key-not-for-production
DEBUG=1

# ---------- PostgreSQL ----------
POSTGRES_DB=ft_transcendence
POSTGRES_USER=ft_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis_broker
REDIS_PORT=6379
REDIS_PASSWORD=devpassword_redis

# ---------- JWT ----------
JWT_SECRET_KEY=dev-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------- OAuth (42 API) ----------
OAUTH_42_CLIENT_ID=your_42_client_id
OAUTH_42_CLIENT_SECRET=your_42_client_secret
OAUTH_42_REDIRECT_URI=https://localhost/api/auth/oauth/callback

# ---------- AI Service ----------
AI_SERVICE_HOST=ai_service
AI_SERVICE_PORT=8002

# ---------- Game Service ----------
GAME_SCORE_LIMIT=5
GAME_TIME_LIMIT_SECONDS=180
GAME_SIMULATION_FPS=60
GAME_BROADCAST_FPS=30
GAME_MAX_PLAYERS_PER_TEAM=1

# ---------- Frontend ----------
REACT_APP_API_URL=https://localhost/api


